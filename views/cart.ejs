<%- include('partials/header') %>

<h1><%= t('cart.title') %></h1>

<% if (paymentCancelled) { %>
  <div class="notice warning"><%= t('cart.paymentCancelled') %></div>
<% } %>
<% if (errorType === 'availability' || hasIssue) { %>
  <div class="notice error"><%= t('cart.unavailableNotice') %></div>
<% } else if (errorType === 'email') { %>
  <div class="notice error"><%= t('cart.emailMismatch') %></div>
<% } else if (errorType) { %>
  <div class="notice error"><%= t('cart.errorGeneric') %></div>
<% } %>

<% if (!items.length) { %>
  <p><%= t('cart.empty') %></p>
  <a class="btn" href="/<%= lang %>/"><%= t('cart.backToHome') %></a>
<% } else { %>
  <table class="cart-table">
    <thead>
      <tr>
        <th><%= t('cart.event') %></th>
        <th><%= t('cart.type') %></th>
        <th><%= t('cart.outboundTime') %></th>
        <th><%= t('cart.returnTime') %></th>
        <th><%= t('cart.people') %></th>
        <th><%= t('cart.price') %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(function (item, index) { %>
        <tr>
          <td><%= eventName(item.event, lang) %></td>
          <td><%= t('home.' + TYPE_TO_I18N_KEY[item.type]) %></td>
          <td><%= item.andataSlot ? formatTime(item.andataSlot.departureAt, lang) : '—' %></td>
          <td><%= item.ritornoSlot ? formatTime(item.ritornoSlot.departureAt, lang) : '—' %></td>
          <td><%= item.numPeople %></td>
          <td>
            <%= formatEuro(item.priceEuroCents) %> €
            <% if (item.insufficient) { %>
              <br><small style="color:var(--color-danger);">⚠ <%= item.seatsAvailable %> <%= t('home.seatsLeft') %></small>
            <% } %>
          </td>
          <td>
            <form method="POST" action="/<%= lang %>/cart/remove/<%= index %>">
              <button type="submit" class="btn-secondary"><%= t('cart.remove') %></button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p class="cart-total"><%= t('cart.total') %>: <strong><%= formatEuro(total) %> €</strong></p>

  <% if (!hasIssue) { %>
    <h2><%= t('cart.continueTitle') %></h2>
    <form method="POST" action="/<%= lang %>/checkout">
      <div class="form-row">
        <label for="name"><%= t('cart.name') %></label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="form-row">
        <label for="email"><%= t('cart.email') %></label>
        <input type="email" id="email" name="email" required>
      </div>
      <div class="form-row">
        <label for="emailConfirm"><%= t('cart.emailConfirm') %></label>
        <input type="email" id="emailConfirm" name="emailConfirm" required>
      </div>
      <%# Solo Stripe (carta) è offerto in questa pagina. Il backend PayPal resta
          attivo e configurato: per riattivare l'opzione basta rimettere il
          secondo radio button (value="paypal") qui sotto. %>
      <input type="hidden" name="paymentMethod" value="stripe">
      <button type="submit"><%= t('cart.submit') %></button>
    </form>
  <% } %>

  <p style="margin-top:20px;"><a href="/<%= lang %>/"><%= t('cart.backToHome') %></a></p>
<% } %>

<%- include('partials/footer') %>
