<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pannello prenotazioni – Sette Lune</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/admin">Pannello prenotazioni</a>
      <form method="POST" action="/admin/logout">
        <button type="submit" class="btn-secondary">Esci</button>
      </form>
    </div>
  </header>
  <main class="container">
    <% if (resetDone) { %>
      <div class="notice success">Tutte le prenotazioni sono state cancellate e i posti azzerati.</div>
    <% } %>

    <p class="event-meta">
      Prenotazioni pagate: <strong><%= paidCount %></strong> ·
      In attesa di pagamento (hold attivo): <strong><%= pendingCount %></strong>
    </p>

    <p class="event-meta">
      <a href="/admin/export-all.csv">Esporta tutte le prenotazioni (CSV)</a>
    </p>

    <details style="margin: 20px 0; padding: 12px; border: 1px solid var(--color-danger, #c0392b); border-radius: 6px;">
      <summary style="cursor: pointer; color: var(--color-danger, #c0392b); font-weight: bold;">
        Azzera tutte le prenotazioni e libera tutti i posti
      </summary>
      <p style="margin-top: 10px;">
        Cancella <strong>definitivamente</strong> tutte le prenotazioni (pagate e in attesa)
        e riporta tutti i posti allo stato libero. Usalo solo per ripulire i dati di test
        prima di aprire le vendite vere: <strong>non usarlo dopo</strong>, perché
        cancellerebbe anche le prenotazioni reali dei clienti.
      </p>
      <form method="POST" action="/admin/reset-bookings"
            onsubmit="return confirm('Sei sicuro? Questa azione cancella TUTTE le prenotazioni e non si può annullare.');">
        <button type="submit" class="btn-secondary" style="border-color: var(--color-danger, #c0392b); color: var(--color-danger, #c0392b);">
          Azzera tutto
        </button>
      </form>
    </details>

    <% events.forEach(function (event) { %>
      <div class="event-card">
        <h2><%= event.nameIt %></h2>
        <p class="event-meta"><%= event.descriptionIt %></p>

        <h3>Andata</h3>
        <table class="admin-table">
          <thead><tr><th>Orario</th><th>Prenotati</th><th>In attesa</th><th>Liberi</th><th></th></tr></thead>
          <tbody>
            <% event.slots.filter(function (s) { return s.direction === 'ANDATA'; }).forEach(function (slot) { %>
              <tr>
                <td><%= formatDateLong(slot.departureAt, 'it') %> — <%= formatTime(slot.departureAt, 'it') %></td>
                <td><%= slot.capacityBooked %></td>
                <td><%= slot.capacityHeld %></td>
                <td><%= slot.capacityTotal - slot.capacityBooked - slot.capacityHeld %> / <%= slot.capacityTotal %></td>
                <td>
                  <a href="/admin/slot/<%= slot.id %>">Vedi lista</a> ·
                  <a href="/admin/slot/<%= slot.id %>/export.csv">CSV</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <h3>Ritorno</h3>
        <table class="admin-table">
          <thead><tr><th>Orario</th><th>Prenotati</th><th>In attesa</th><th>Liberi</th><th></th></tr></thead>
          <tbody>
            <% event.slots.filter(function (s) { return s.direction === 'RITORNO'; }).forEach(function (slot) { %>
              <tr>
                <td><%= formatDateLong(slot.departureAt, 'it') %> — <%= formatTime(slot.departureAt, 'it') %></td>
                <td><%= slot.capacityBooked %></td>
                <td><%= slot.capacityHeld %></td>
                <td><%= slot.capacityTotal - slot.capacityBooked - slot.capacityHeld %> / <%= slot.capacityTotal %></td>
                <td>
                  <a href="/admin/slot/<%= slot.id %>">Vedi lista</a> ·
                  <a href="/admin/slot/<%= slot.id %>/export.csv">CSV</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% }) %>
  </main>
</body>
</html>
