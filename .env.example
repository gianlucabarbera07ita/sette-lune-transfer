# --- Database (fornito automaticamente da Render se usi render.yaml) ---
DATABASE_URL="postgresql://user:password@localhost:5432/settelune"

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL="https://IL-TUO-SITO.onrender.com"
SESSION_SECRET="cambia-questa-stringa-con-una-lunga-e-casuale"
CART_COOKIE_SECRET="cambia-anche-questa-con-un-altra-stringa-casuale"

# --- Admin ---
ADMIN_PASSWORD="scegli-una-password-forte-per-il-pannello-admin"

# --- Stripe ---
# Chiavi da https://dashboard.stripe.com/apikeys (usa quelle "sk_test_..." finche' non sei pronto a incassare davvero)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- PayPal ---
# Credenziali da https://developer.paypal.com/dashboard/applications (crea una "App" collegata al tuo account Business)
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
# "sandbox" per i test, "live" quando sei pronto a incassare davvero
PAYPAL_ENV="sandbox"
# Webhook ID che ottieni configurando il webhook nella dashboard PayPal (vedi README)
PAYPAL_WEBHOOK_ID="..."

# --- Email (Gmail SMTP) ---
GMAIL_USER="tuonome@gmail.com"
# Non la password normale del tuo account: una "App Password" generata da
# https://myaccount.google.com/apppasswords (richiede la verifica in due passaggi attiva)
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
# Email che ricevono la notifica interna ad ogni nuova prenotazione (separate da virgola)
INTERNAL_NOTIFICATION_EMAILS="gianluca.barbera07@gmail.com"
